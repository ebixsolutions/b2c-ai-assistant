
# --- Database (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=b2c-v1
DB_USER=postgres
DB_PASSWORD=postgres

# How many products each rule returns (top-N).
PRODUCT_LIMIT=5

# --- AI explanation layer (optional, Vertex AI / Gemini) ---
# When false, the static detection/reason text is returned verbatim.
IS_AI_ENABLE=false
# Required only when IS_AI_ENABLE=true.
PROJECT_ID=vertex-ai-api-491406
LOCATION=us-central1
MODEL=gemini-2.5-flash
# Path to a Google Cloud service-account key JSON file (relative to this folder
# or absolute). Download it from the GCP console for a service account that has
# the "Vertex AI User" role. This file is secret — keep it out of git.
GOOGLE_APPLICATION_CREDENTIALS=google-credentials.json

# --- TopView AI Video ---
TOPVIEW_API_KEY=your_topview_api_key_here
TOPVIEW_UID=your_topview_uid_here
AI_VIDEO_DEFAULT_DURATION=4
